{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "console_title_template": "{{ if .Root }}root @ {{ end }}{{ .Shell }} in {{ .Folder }}",
  "palette": {
      "davy-grey": "#575656",
      "light-grey": "#D6DEEB",
      "dark-grey": "#99908A",
      "charcoal-grey": "#414141",
      "sky-blue": "#00C7FC",
      "black-pearl": "#011627",
      "reddish-orange": "#EF541C",
      "ultramarine-blue": "#516BEB",
      "aquamarine-blue": "#79DFE1",
      "white": "#ffffff",
      "green-white": "#E8EAEE",
      "spanish-white": "#F2D3B6",
      "sea-green": "#1E9748",
      "light-gold": "#FFDE57",
      "aqua-blue": "#03DED3",
      "cyan-blue": "#193549",
      "marine-blue": "#7FD5EA",
      "carmine-pink": "#E44141",
      "light-pink": "#FEF5ED",
      "pale-aqua": "#B6D6F2",
      "git-background": "#1BD4CD",
      "git-foreground": "#193549",
      "git-modified": "#FF9248",
      "git-diverged": "#FF4500",
      "git-ahead": "#B787D7",
      "git-behind": "#B787D7",
      "git-clean": "#CAEBE1"
  },
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "background": "p:davy-grey",
          "foreground": "p:light-grey",
          "leading_diamond": "\ue0b6",
          "options": {
            "alpine": "\uf300",
            "arch": "\uf303",
            "centos": "\uf304",
            "debian": "\uf306",
            "elementary": "\uf309",
            "fedora": "\uf30a",
            "gentoo": "\uf30d",
            "linux": "\ue712",
            "macos": "\ue711",
            "manjaro": "\uf312",
            "mint": "\uf30f",
            "opensuse": "\uf314",
            "raspbian": "\uf315",
            "ubuntu": "\uf31c",
            "windows": "\ue70f"
          },
          "style": "diamond",
          "template": " {{ if .WSL }}\ue712 on {{ end }}{{ .Icon }} ",
          "type": "os"
        },
        {
          "background": "p:sky-blue",
          "foreground": "p:black-pearl",
          "powerline_symbol": "\ue0b0",
          "style": "powerline",
          "template": " \uf489 {{ .UserName }} ",
          "type": "shell"
        },
        {
          "background": "p:reddish-orange",
          "foreground": "p:light-grey",
          "powerline_symbol": "\ue0b0",
          "style": "powerline",
          "template": " \uf09c admin ",
          "type": "root"
        },
        {
          "background": "p:ultramarine-blue",
          "foreground": "p:white",
          "style": "diamond",
          "template": "\ue266 MEM: {{ round .PhysicalPercentUsed .Precision }}% | {{ (div ((sub .PhysicalTotalMemory .PhysicalAvailableMemory)|float64) 1073741824.0) }}/{{ (div .PhysicalTotalMemory 1073741824.0) }}GB \ue266 ",
          "trailing_diamond": "\ue0b0",
          "type": "sysinfo"
        },
        {
          "type": "cmake",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "p:green-white",
          "background": "p:sea-green",
          "template": " \ue61e \ue61d cmake {{ .Full }} "
        },
        {
          "type": "python",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "options": {
            "display_mode": "context"
          },
          "foreground": "p:black-pearl",
          "background": "p:light-gold",
          "template": " \ue73c {{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }} "
        },
        {
          "type": "go",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "p:white",
          "background": "p:marine-blue",
          "template": " \u202d\ue626 {{ .Full }} "
        },
        {
          "type": "rust",
          "style": "powerline",
          "powerline_symbol": "\ue0b0",
          "foreground": "p:cyan-blue",
          "background": "p:dark-grey",
          "template": " \ue7a8 {{ .Full }} "
        },
        {
          "background": "p:git-background",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}p:git-modified{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}p:git-diverged{{ end }}",
            "{{ if gt .Ahead 0 }}p:git-ahead{{ end }}",
            "{{ if gt .Behind 0 }}p:git-behind{{ end }}"
          ],
          "foreground": "p:git-foreground",
          "powerline_symbol": "\ue0b0",
          "options": {
            "branch_icon": "\ue725 ",
            "fetch_stash_count": true,
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "fetch_worktree_count": true
          },
          "style": "powerline",
          "template": " {{ url .UpstreamIcon .UpstreamURL }}{{ url .HEAD .UpstreamURL }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }}<p:git-clean> \uf046 {{ .Staging.String }}</>{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} ",
          "type": "git"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "segments": [
        {
          "background": "p:aqua-blue",
          "background_templates": [
            "{{ if gt .Code 0 }}p:carmine-pink{{ end }}"
          ],
          "foreground": "p:charcoal-grey",
          "foreground_templates": [
            "{{ if gt .Code 0 }}p:light-grey{{ end }}"
          ],
          "leading_diamond": "\ue0b6",
          "options": {
            "always_enabled": true
          },
          "style": "diamond",
          "template": " {{ if gt .Code 0 }}\uf00d{{ else }}\uf00c{{ end }} ",
          "type": "status"
        },
        {
          "background": "p:davy-grey",
          "foreground": "p:light-grey",
          "options": {
            "style": "roundrock",
            "threshold": 0
          },
          "style": "diamond",
          "template": " \uf252 {{ .FormattedMs }} ",
          "trailing_diamond": "\ue0b4",
          "type": "executiontime"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "p:light-grey",
          "style": "plain",
          "template": "\u256d\u2500",
          "type": "text"
        },
        {
          "foreground": "p:spanish-white",
          "options": {
            "time_format": "<p:light-grey>\ue641 15:04:05</> <p:aquamarine-blue>|</> \uf073 2 Jan, Monday"
          },
          "style": "plain",
          "template": "{{ .CurrentDate | date .Format }} <p:aquamarine-blue>|</>",
          "type": "time"
        },
        {
          "foreground": "p:pale-aqua",
          "leading_diamond": "<p:sky-blue> \uf07b </><p:pale-aqua> in </>",
          "options": {
            "folder_icon": " \uf07c ",
            "folder_separator_icon": " \uf061 ",
            "home_icon": "\ueb06 ",
            "style": "agnoster_short",
            "max_depth": 3
          },
          "style": "diamond",
          "template": " {{ path .Path .Location }} ",
          "type": "path"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "p:light-grey",
          "style": "plain",
          "template": "\u2570\u2500",
          "type": "text"
        },
        {
          "foreground": "p:light-grey",
          "options": {
            "always_enabled": true
          },
          "style": "plain",
          "template": "\u276f\u276f ",
          "type": "status"
        }
      ],
      "type": "prompt"
    }
  ],
  "osc99": true,
  "transient_prompt": {
    "background": "transparent",
    "foreground": "p:light-pink",
    "template": "\ue285 "
  },
  "secondary_prompt": {
    "background": "transparent",
    "foreground": "p:light-grey",
    "template": "\u2570\u2500\u276f "
  },
  "author": "Stanley Omoregie",
  "version": 4
}
