{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "console_title_template": "{{ if .Root }}root @ {{ end }}{{ .Shell }} in {{ .Folder }}",
  "palette": {
      "angular-foreground": "#ce092f",
      "aurelia-foreground": "#de1f84",
      "aws-background": "#565656",
      "aws-foreground": "#faa029",
      "az-foreground": "#337bb6",
      "azfunc-foreground": "#5398c2",
      "azfunc-tempcolor": "#f5bf45",
      "baltic-sea": "#262626",
      "battery-background": "#f36943",
      "battery-charging": "#b8e994",
      "battery-discharging": "#fff34e",
      "battery-full": "#33DD2D",
      "canary-yellow": "#FFFB38",
      "cds-background": "#5a7a94",
      "cds-foreground": "#100e23",
      "cf-foreground": "#1d5185",
      "cmake-background": "##d2d2d2",
      "cmake-foreground": "#01a300",
      "cmake-tempcolor-1": "#2829b2",
      "cmake-tempcolor-2": "#be1818",
      "dart-background": "#e1e8e9",
      "dart-foreground": "#055b9c",
      "datetime-background": "#40c4ff",
      "dotnet-background": "#0e0e0e",
      "dotnet-foreground": "#0d6da8",
      "executiontime-background": "#83769c",
      "flutter-background": "#06A4CE",
      "git-background": "#FFFB38",
      "git-foreground": "#011627",
      "git-modified": "#ffeb95",
      "git-diverged": "#c5e478",
      "git-ahead": "#C792EA",
      "git-behind": "#C792EA",
      "go-foreground": "#06aad5",
      "haskell-foreground": "#906cff",
      "java-foreground": "#ec2729",
      "julia-background": "#945bb3",
      "julia-tempcolor": "#ca3c34",
      "kubectl-background": "#316ce4",
      "lua-foreground": "#000081",
      "npm-icon": "#cc3a3a",
      "nx-background": "#6488c0",
      "nx-foreground": "#1e293b",
      "os-background": "#0077c2",
      "path-background": "#82AAFF",
      "perl-background": "#41436d",
      "php-background": "#787CB5",
      "primary-foreground": "#000000",
      "python-background": "#306998",
      "python-foreground": "#FFE873",
      "r-background": "#b9bbbf",
      "r-foreground": "#1c68bd",
      "ruby-foreground": "#9c1006",
      "secondary-foreground": "#011627",
      "shell-background": "#d6deeb",
      "spotify-background": "#1DB954",
      "status-background": "#22da6e",
      "swift-background": "#fe562e",
      "sysinfo-background": "#8f43f3",
      "username-background": "#21c7a8",
      "valentine-red": "#ef5350",
      "white": "#ffffff",
      "yarn-background": "#303030",
      "yarn-foreground": "#3C873A",
      "yarn-icon": "#348cba"
  },
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "background": "p:os-background",
          "foreground": "p:white",
          "leading_diamond": "\u256d\u2500\ue0b6",
          "options": {
            "windows": "\ue62a"
          },
          "style": "diamond",
          "template": " {{ if .WSL }}WSL at {{ end }}{{.Icon}}  ",
          "trailing_diamond": "\ue0b0",
          "type": "os"
        },
        {
          "background": "p:valentine-red",
          "foreground": "p:canary-yellow",
          "powerline_symbol": "\ue0b0",
          "style": "powerline",
          "template": "<parentBackground>\ue0b0</> \uf292 ",
          "type": "root"
        },
        {
          "background": "p:username-background",
          "foreground": "p:secondary-foreground",
          "style": "diamond",
          "template": " {{ .UserName }}  ",
          "trailing_diamond": "\ue0b0",
          "type": "shell"
        },
        {
          "background": "p:path-background",
          "foreground": "p:secondary-foreground",
          "powerline_symbol": "\ue0b0",
          "options": {
            "folder_icon": " \uf07b ",
            "home_icon": "\ue617",
            "style": "folder"
          },
          "style": "powerline",
          "template": " \uf07b\uea9c {{ path .Path .Location }} ",
          "type": "path"
        },
        {
          "background": "p:git-background",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}p:git-modified{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}p:git-diverged{{ end }}",
            "{{ if gt .Ahead 0 }}p:git-ahead{{ end }}",
            "{{ if gt .Behind 0 }}p:git-behind{{ end }}"
          ],
          "foreground": "p:git-foreground",
          "powerline_symbol": "\ue0b0",
          "options": {
            "branch_icon": "\ue725 ",
            "fetch_status": true,
            "fetch_upstream_icon": true,
            "mapped_branches": {
              "feat/*": "🚀 ",
              "bug/*": "🐛 "
            }
          },
          "style": "powerline",
          "template": " {{ url .UpstreamIcon .UpstreamURL }}{{ url .HEAD .UpstreamURL }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }}<p:valentine-red> \uf046 {{ .Staging.String }}</>{{ end }} ",
          "type": "git"
        },
        {
          "background": "p:executiontime-background",
          "foreground": "p:white",
          "leading_diamond": "\ue0d7",
          "options": {
            "style": "roundrock",
            "threshold": 0
          },
          "style": "diamond",
          "template": " \ueba2 {{ .FormattedMs }}\u2800",
          "trailing_diamond": "\ue0b4",
          "type": "executiontime"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "right",
      "overflow": "break",
      "segments": [
        {
          "background": "p:shell-background",
          "foreground": "p:secondary-foreground",
          "leading_diamond": "\ue0b6",
          "style": "diamond",
          "template": "\uf489  {{ .Name }} ",
          "trailing_diamond": "\ue0d6",
          "type": "shell"
        },
        {
          "background": "p:sysinfo-background",
          "foreground": "p:white",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue266 MEM: {{ round .PhysicalPercentUsed .Precision }}% | {{ (div ((sub .PhysicalTotalMemory .PhysicalAvailableMemory)|float64) 1073741824.0) }}/{{ (div .PhysicalTotalMemory 1073741824.0) }}GB \ue266 ",
          "trailing_diamond": "\ue0d6",
          "type": "sysinfo"
        },
        {
          "background": "p:battery-background",
          "background_templates": [
            "{{if eq \"Charging\" .State.String}}p:battery-charging{{end}}",
            "{{if eq \"Discharging\" .State.String}}p:battery-discharging{{end}}",
            "{{if eq \"Full\" .State.String}}p:battery-full{{end}}"
          ],
          "foreground": "p:baltic-sea",
          "invert_powerline": true,
          "powerline_symbol": "\ue0b2",
          "properties": {
            "charged_icon": "\uf240 ",
            "charging_icon": "\uf1e6 ",
            "discharging_icon": "\ue234 "
          },
          "style": "powerline",
          "template": " {{ if not .Error }}{{ .Icon }}{{ .Percentage }}{{ end }}{{ .Error }}\uf295 ",
          "type": "battery"
        },
        {
          "background": "p:yarn-background",
          "foreground": "p:yarn-foreground",
          "leading_diamond": "\ue0b2",
          "options": {
            "fetch_package_manager": true,
            "npm_icon": "<p:fnpm-icon>\ue71e</> ",
            "yarn_icon": "<p:yarn-icon>\ue6a7</> "
          },
          "style": "diamond",
          "template": "\ue718 {{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}{{ .Full }} ",
          "trailing_diamond": "\ue0d6",
          "type": "node"
        },
        {
          "background": "p:white",
          "foreground": "p:angular-foreground",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue753 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "trailing_diamond": "\ue0d6",
          "type": "angular"
        },
        {
          "background": "p:white",
          "foreground": "p:aurelia-foreground",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\u03b1 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "trailing_diamond": "\ue0d6",
          "type": "aurelia"
        },
        {
          "background": "p:aws-background",
          "foreground": "p:aws-foreground",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue7ad {{ .Profile }}{{ if .Region }}@{{ .Region }}{{ end }} ",
          "trailing_diamond": "\ue0d6",
          "type": "aws"
        },
        {
          "background": "p:white",
          "foreground": "p:az-foreground",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\uebd8 {{ .EnvironmentName }} ",
          "trailing_diamond": "\ue0d6",
          "type": "az"
        },
        {
          "background": "p:white",
          "foreground": "p:azfunc-foreground",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\uf104<p:azfunc-tempcolor>\uf0e7</>\uf105 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "trailing_diamond": "\ue0d6",
          "type": "azfunc"
        },
        {
          "background": "p:cds-background",
          "foreground": "p:cds-foreground",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue311  cds {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "trailing_diamond": "\ue0d6",
          "type": "cds"
        },
        {
          "background": "p:white",
          "foreground": "p:primary-foreground",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\uE370 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "trailing_diamond": "\ue0d6",
          "type": "crystal"
        },
        {
          "background": "p:white",
          "foreground": "p:cf-foreground",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\uf40a  cf {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "trailing_diamond": "\ue0d6",
          "type": "cf"
        },
        {
          "background": "p:white",
          "foreground": "p:cf-foreground",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\uf40a {{if .Org }}{{ .Org }}{{ end }}{{ if .Space }}/{{ .Space }}{{ end }} ",
          "trailing_diamond": "\ue0d6",
          "type": "cftarget"
        },
        {
          "background": "p:cmake-background",
          "foreground": "p:cmake-foreground",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "<p:cmake-tempcolor-1>\ue61e</> <p:cmake-tempcolor-2>\ue61d</>  cmake {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "trailing_diamond": "\ue0d6",
          "type": "cmake"
        },
        {
          "background": "p:dart-background",
          "foreground": "p:dart-foreground",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue798 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "trailing_diamond": "\ue0d6",
          "type": "dart"
        },
        {
          "background": "p:dotnet-background",
          "foreground": "p:dotnet-foreground",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue77f  {{ if .Unsupported }}\uf071{{ else }}{{ .Full }}{{ end }} ",
          "trailing_diamond": "\ue0d6",
          "type": "dotnet"
        },
        {
          "background": "p:flutter-background",
          "foreground": "p:white",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue28e {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "trailing_diamond": "\ue0d6",
          "type": "flutter"
        },
        {
          "background": "p:white",
          "foreground": "p:go-foreground",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue626 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "trailing_diamond": "\ue0d6",
          "type": "go"
        },
        {
          "background": "p:cds-foreground",
          "foreground": "p:haskell-foreground",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue61f {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "trailing_diamond": "\ue0d6",
          "type": "haskell"
        },
        {
          "background": "p:white",
          "foreground": "p:java-foreground",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue738 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "trailing_diamond": "\ue0d6",
          "type": "java"
        },
        {
          "background": "p:julia-background",
          "foreground": "p:white",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "<p:julia-tempcolor>\ue624</> {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "trailing_diamond": "\ue0d6",
          "type": "julia"
        },
        {
          "background": "p:kotlin-background",
          "foreground": "p:white",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "K {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "trailing_diamond": "\ue0d6",
          "type": "kotlin"
        },
        {
          "background": "p:kubectl-background",
          "foreground": "p:white",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\uf308 {{.Context}} :: {{if .Namespace}}{{.Namespace}}{{else}}default{{end}} ",
          "trailing_diamond": "\ue0d6",
          "type": "kubectl"
        },
        {
          "background": "p:white",
          "foreground": "p:lua-foreground",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue620 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "trailing_diamond": "\ue0d6",
          "type": "lua"
        },
        {
          "background": "p:nx-background",
          "foreground": "p:nx-foreground",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "Nx {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "trailing_diamond": "\ue0d6",
          "type": "nx"
        },
        {
          "background": "p:perl-background",
          "foreground": "p:white",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue769 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "trailing_diamond": "\ue0d6",
          "type": "perl"
        },
        {
          "background": "p:php-background",
          "foreground": "p:primary-foreground",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue73d {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "trailing_diamond": "\ue0d6",
          "type": "php"
        },
        {
          "background": "p:python-background",
          "foreground": "p:python-foreground",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue235  {{ if .Error }}{{ .Error }}{{ else }}{{ if .Venv }}{{ .Venv }} {{ end }}{{ .Full }}{{ end }}",
          "trailing_diamond": "\ue0d6",
          "type": "python"
        },
        {
          "background": "p:r-background",
          "foreground": "p:r-foreground",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "R {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "trailing_diamond": "\ue0d6",
          "type": "r"
        },
        {
          "background": "p:white",
          "foreground": "p:ruby-foreground",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue791 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "trailing_diamond": "\ue0d6",
          "type": "ruby"
        },
        {
          "background": "p:white",
          "foreground": "p:primary-foreground",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue7a8 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "trailing_diamond": "\ue0d6",
          "type": "rust"
        },
        {
          "background": "p:swift-background",
          "foreground": "p:white",
          "leading_diamond": "\ue0b2",
          "style": "diamond",
          "template": "\ue755 {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }} ",
          "trailing_diamond": "\ue0d6",
          "type": "swift"
        },
        {
          "background": "p:datetime-background",
          "foreground": "p:white",
          "invert_powerline": true,
          "leading_diamond": "\ue0b2",
          "options": {
            "time_format": "_2.01.0000,15:04"
          },
          "style": "diamond",
          "template": " \uf073 {{ dateInZone \"06-01-02\" (now) \"UTC\" | date \"02.01.06,15:04\" }} ",
          "trailing_diamond": "\ue0b4",
          "type": "time"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "p:username-background",
          "style": "plain",
          "template": "\u2570\u2500",
          "type": "text"
        },
        {
          "background": "p:spotify-background",
          "foreground": "p:secondary-foreground",
          "leading_diamond": "\ue0b6",
          "options": {
            "playing_icon": "\uf1bc "
          },
          "style": "diamond",
          "template": " {{ .Icon }}{{ if ne .Status \"stopped\" }}{{ .Artist }} ~ {{ .Track }}{{ end }} ",
          "trailing_diamond": "\ue0c6 ",
          "type": "spotify"
        },
        {
          "foreground": "p:status-background",
          "foreground_templates": ["{{ if gt .Code 0 }}p:valentine-red{{ end }}"],
          "options": {
            "always_enabled": true
          },
          "style": "plain",
          "template": "\ue285\ue285",
          "type": "status"
        }
      ],
      "type": "prompt"
    }
  ],
  "final_space": true,
  "transient_prompt": {
    "background": "transparent",
    "foreground": "p:shell-background",
    "template": "\ue285 "
  },
  "author": "Stanley Omoregie",
  "version": 4
}
